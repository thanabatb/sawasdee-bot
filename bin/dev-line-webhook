#!/usr/bin/env sh

set -eu

cd "$(dirname "$0")/.."

if [ -f .env.local ]; then
  set -a
  . ./.env.local
  set +a
elif [ -f .env ]; then
  set -a
  . ./.env
  set +a
fi

PORT="${PORT:-3000}"
WAIT_SECONDS="${WAIT_SECONDS:-120}"
SERVER_LOG="/tmp/sawasdee-bot-server.log"
TUNNEL_LOG="/tmp/sawasdee-bot-tunnel.log"

if ! command -v npm >/dev/null 2>&1; then
  echo "npm is not installed or not on PATH."
  exit 1
fi

if ! command -v ngrok >/dev/null 2>&1; then
  echo "ngrok is not installed. Run: brew install ngrok"
  echo "Then authenticate: ngrok config add-authtoken <your-token>"
  echo "Get your token at: https://dashboard.ngrok.com/get-started/your-authtoken"
  exit 1
fi

cleanup() {
  if [ -n "${SERVER_PID:-}" ]; then
    kill "$SERVER_PID" 2>/dev/null || true
  fi
  if [ -n "${TUNNEL_PID:-}" ]; then
    kill "$TUNNEL_PID" 2>/dev/null || true
  fi
}

trap cleanup EXIT INT TERM

if curl -fsS "http://localhost:${PORT}/health" >/dev/null 2>&1; then
  echo "Using existing local server on http://localhost:${PORT}"
else
  echo "Starting local LINE webhook server on http://localhost:${PORT} ..."
  nohup npm run serve:local >"$SERVER_LOG" 2>&1 &
  SERVER_PID=$!
fi

echo "Waiting for /health to become reachable..."
for i in $(seq 1 "$WAIT_SECONDS"); do
  if curl -fsS "http://localhost:${PORT}/health" >/dev/null 2>&1; then
    break
  fi

  if [ "$i" -eq "$WAIT_SECONDS" ]; then
    echo "Local webhook server did not become ready after ${WAIT_SECONDS} seconds."
    cat "$SERVER_LOG" 2>/dev/null || true
    exit 1
  fi

  sleep 1
done

echo "Starting public tunnel with ngrok..."
rm -f "$TUNNEL_LOG"
ngrok http "$PORT" --log=stdout --log-format=json >"$TUNNEL_LOG" 2>&1 &
TUNNEL_PID=$!

echo "Waiting for tunnel URL..."
for i in $(seq 1 30); do
  TUNNEL_BASE_URL="$(grep -o '"url":"https://[^"]*"' "$TUNNEL_LOG" 2>/dev/null | head -n 1 | grep -o 'https://[^"]*' || true)"
  if [ -n "$TUNNEL_BASE_URL" ]; then
    TUNNEL_URL="$TUNNEL_BASE_URL/webhook/line"
    echo
    echo "LINE Messaging API webhook endpoint:"
    echo "$TUNNEL_URL"
    echo
    echo "Paste that URL into LINE Developers > Messaging API > Webhook URL."
    echo "Keep this process running while testing bot commands."
    echo
    wait "$TUNNEL_PID"
    exit $?
  fi

  if ! kill -0 "$TUNNEL_PID" 2>/dev/null; then
    echo "ngrok exited unexpectedly. Check if authtoken is configured:"
    echo "  ngrok config add-authtoken <your-token>"
    cat "$TUNNEL_LOG" 2>/dev/null || true
    exit 1
  fi

  sleep 1
done

echo "Timed out waiting for ngrok URL."
cat "$TUNNEL_LOG" 2>/dev/null || true
exit 1

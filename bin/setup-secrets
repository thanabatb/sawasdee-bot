#!/usr/bin/env bash
# Run once to store prod secrets in GCP Secret Manager
# Usage: bash bin/setup-secrets
set -euo pipefail

PROJECT=$(gcloud config get-value project)
echo "Setting up secrets for project: $PROJECT"

create_secret() {
  local name=$1
  local value=$2
  if gcloud secrets describe "$name" --project="$PROJECT" &>/dev/null; then
    echo "$value" | gcloud secrets versions add "$name" --data-file=- --project="$PROJECT"
    echo "  Updated: $name"
  else
    echo "$value" | gcloud secrets create "$name" --data-file=- --project="$PROJECT"
    echo "  Created: $name"
  fi
}

echo ""
echo "Paste your prod values when prompted."
echo ""

read -rp "LINE_CHANNEL_ACCESS_TOKEN: " LINE_CHANNEL_ACCESS_TOKEN
read -rp "LINE_CHANNEL_SECRET: " LINE_CHANNEL_SECRET
read -rp "FIREBASE_PROJECT_ID: " FIREBASE_PROJECT_ID
read -rp "FIREBASE_CLIENT_EMAIL: " FIREBASE_CLIENT_EMAIL
read -rp "FIREBASE_PRIVATE_KEY (paste full key, press Enter then Ctrl+D): " -d $'\x04' FIREBASE_PRIVATE_KEY
echo ""
read -rp "FIREBASE_STORAGE_BUCKET: " FIREBASE_STORAGE_BUCKET
read -rp "ADMIN_SECRET: " ADMIN_SECRET

create_secret "LINE_CHANNEL_ACCESS_TOKEN" "$LINE_CHANNEL_ACCESS_TOKEN"
create_secret "LINE_CHANNEL_SECRET" "$LINE_CHANNEL_SECRET"
create_secret "FIREBASE_PROJECT_ID" "$FIREBASE_PROJECT_ID"
create_secret "FIREBASE_CLIENT_EMAIL" "$FIREBASE_CLIENT_EMAIL"
create_secret "FIREBASE_PRIVATE_KEY" "$FIREBASE_PRIVATE_KEY"
create_secret "FIREBASE_STORAGE_BUCKET" "$FIREBASE_STORAGE_BUCKET"
create_secret "ADMIN_SECRET" "$ADMIN_SECRET"

echo ""
echo "All secrets stored. Run bin/deploy to deploy to Cloud Run."

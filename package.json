{
  "name": "sawasdee-bot",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --watch --import tsx src/index.ts",
    "serve:local": "node --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "seed:templates": "node --import tsx src/scripts/seedTemplates.ts",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "line",
    "firebase",
    "bot",
    "greeting"
  ],
  "author": "",
  "license": "ISC",
  "description": "LINE bot for daily and occasion greeting images built with Firebase.",
  "dependencies": {
    "@line/bot-sdk": "^11.0.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "localtunnel": "^2.0.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
